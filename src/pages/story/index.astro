---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const chapters = (await getCollection('story')).sort((a, b) => a.data.chapter - b.data.chapter);
const series = [...new Set(chapters.map((chapter) => chapter.data.series))];
---
<BaseLayout title="Story">
  <PageHero kicker="Literary archive" title="Story" lead="Project UNAC fiction is arranged as a quiet ebook reader: chapter order, dated entries, and a narrow page built for sustained reading rather than announcements." />
  <section class="section">
    <div class="container editorial-grid">
      <div class="section-head">
        <p class="kicker">Series / first archive</p>
        <h2 class="display-lg">{series[0]}</h2>
        <p class="body-copy">The first public sequence follows the opening of the Black Gate and the archive keeper assigned to a world that writes back. Each chapter is filed as part of the same literary record.</p>
      </div>
      <div class="line-list" aria-label="Chapter index">
        {chapters.map((chapter) => (
          <article class="line-item">
            <p class="meta">Chapter {String(chapter.data.chapter).padStart(2, '0')} / {chapter.data.published}</p>
            <a href={`/story/${chapter.id}/`}><h3 class="display-sm">{chapter.data.title}</h3></a>
            <p class="body-copy">{chapter.data.excerpt}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
