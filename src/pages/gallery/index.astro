---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const entries = await getCollection('gallery');
const categories = ['World Art', 'Character Art', 'Music Visuals', 'Archive / Origins'] as const;
const categoryNotes: Record<(typeof categories)[number], string> = {
  'World Art': 'Environment, signal, and setting records selected for their canon value.',
  'Character Art': 'Character files will open only when designs are approved for public archive use.',
  'Music Visuals': 'Visual material attached to SHINHWI releases and Project UNAC soundtrack entries.',
  'Archive / Origins': 'Origin studies and marks preserved because they explain the project surface.'
};
---
<BaseLayout title="Gallery">
  <PageHero kicker="Curated visual archive" title="Gallery" lead="The gallery is a restrained register of selected visual records. Each figure is filed with date, source, and context so the archive feels curated rather than accumulated." />
  <section class="section">
    <div class="container">
      {categories.map((category) => {
        const categoryEntries = entries.filter((entry) => entry.data.category === category);
        return (
          <section class="music-section gallery-category" aria-labelledby={category.toLowerCase().replaceAll(' ', '-')}>
            <div class="section-head">
              <p class="kicker">Visual register</p>
              <h2 id={category.toLowerCase().replaceAll(' ', '-')} class="display-lg">{category}</h2>
              <p class="body-copy">{categoryNotes[category]}</p>
            </div>
            {categoryEntries.length > 0 ? (
              <div class="figure-list">
                {categoryEntries.map((entry) => (
                  <figure class="archive-figure">
                    <figcaption>
                      <p class="archive-label">{entry.data.date} / {entry.data.source}</p>
                      <h3 class="display-sm">{entry.data.title}</h3>
                      <p class="caption">{entry.data.caption}</p>
                    </figcaption>
                  </figure>
                ))}
              </div>
            ) : (
              <p class="archive-label category-hold">No public figures filed in this category.</p>
            )}
          </section>
        );
      })}
    </div>
  </section>
</BaseLayout>
