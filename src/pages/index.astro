---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home">
  <section class="hero-type-band">
    <div class="container">
      <p class="kicker">Official archive / Music portal</p>
      <h1 class="display-xl">Project UNAC</h1>
      <p class="lead">A black-canvas archive where worldbuilding, serialized fiction, music, and restrained visual records are organized as one official body of work.</p>
      <div class="button-row">
        <a class="button-primary" href="/world/">Enter the world</a>
        <a class="button-primary" href="/music/">Music by SHINHWI</a>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container editorial-grid">
      <div class="section-head">
        <p class="kicker">Second fold / symbolic record</p>
        <h2 class="display-lg">Archive surface</h2>
        <p class="body-copy">The site opens slowly: statement first, then record. Images remain rare, deliberate, and bound to their archive context.</p>
      </div>
      <figure class="archive-figure">
        <div class="placeholder-image" aria-hidden="true"></div>
        <figcaption class="caption">Placeholder symbolic image / source pending / version 0.1</figcaption>
      </figure>
    </div>
  </section>
</BaseLayout>
