---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="About">
  <PageHero kicker="SHINHWI" title="About" lead="SHINHWI is the organizing artist identity behind Project UNAC: writing, music direction, visual archive curation, and the slow construction of an official world surface." />
  <section class="section">
    <div class="container editorial-grid">
      <div>
        <h2 class="display-lg">Identity</h2>
        <p class="lead">This page will hold a restrained artist introduction, selected platform links, contact information, and one or two official images when available.</p>
      </div>
      <div class="line-list">
        <article class="line-item">
          <p class="meta">Role</p>
          <h3 class="display-sm">Project author / music archive</h3>
          <p class="body-copy">Placeholder text for the relation between SHINHWI and Project UNAC.</p>
        </article>
        <article class="line-item">
          <p class="meta">Contact</p>
          <h3 class="display-sm">Official channels pending</h3>
          <p class="body-copy">Platform links and contact information will be added after public channel decisions are final.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
