---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="About">
  <PageHero kicker="SHINHWI" title="About" lead="SHINHWI is the artist identity behind Project UNAC, directing the writing, music catalog, world archive, and visual curation as one black-canvas editorial system." />
  <section class="section">
    <div class="container editorial-grid">
      <div>
        <p class="kicker">Identity / authorship</p>
        <h2 class="display-lg">Author of the archive</h2>
        <p class="lead">The work moves between prose, sound, and restrained image-making. Project UNAC is the worldbuilding-based media mix; SHINHWI is the organizing voice that keeps its documents, songs, and surfaces in relation.</p>
      </div>
      <div class="line-list">
        <article class="line-item">
          <p class="meta">Project role</p>
          <h3 class="display-sm">Worldbuilding / fiction / curation</h3>
          <p class="body-copy">SHINHWI maintains the Project UNAC canon through setting records, serialized chapters, and the selection of visual material that belongs in the public archive.</p>
        </article>
        <article class="line-item">
          <p class="meta">Music role</p>
          <h3 class="display-sm">Original catalog / OST direction</h3>
          <p class="body-copy">SHINHWI Originals are kept as artist releases. Project UNAC OST is kept as soundtrack documentation for the world, with each catalog line marked separately.</p>
        </article>
        <article class="line-item">
          <p class="meta">Public surface</p>
          <h3 class="display-sm">Official channels to follow</h3>
          <p class="body-copy">Contact and platform links will be added only as official channels become part of the archive, preserving the site as a precise reference surface rather than a social hub.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
